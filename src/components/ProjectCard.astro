---
interface Props {
    name: string;
    description: string;
    tag: string;
    actions: { href: string; label: string }[];
    image: {
        src: string;
        alt: string;
    };
}

const { name, description, tag, actions, image } = Astro.props;
---

<article class="group flex flex-col h-full transition-colors duration-300 p-2">
    <div
        class="project-img mb-6 aspect-video flex items-center justify-center bg-text/5 overflow-hidden"
    >
        <img
            src={image.src}
            alt={image.alt}
            class="w-full h-full object-cover opacity-80 group-hover:opacity-100 group-hover:scale-105 transition-all duration-500 ease-out"
        />
    </div>

    <div class="flex flex-col grow">
        <div class="flex flex-col items-start gap-2 mb-4">
            <span
                class="label-caps text-[10px] text-accent bg-accent-soft px-2 py-0.5 rounded-sm border border-accent/20"
                >{tag}</span
            >
            <h3 class="text-2xl font-mono tracking-tight text-text">
                {name}
            </h3>
        </div>

        <p class="text-base">
            {description}
        </p>
    </div>

    <div class="flex flex-wrap gap-x-6 gap-y-2 mt-8 pt-4">
        {
            actions.map((action) => (
                <a
                    href={action.href}
                    class="label-caps text-accent no-underline"
                >
                    {action.label}
                </a>
            ))
        }
    </div>
</article>
