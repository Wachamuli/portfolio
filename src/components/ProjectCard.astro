---
interface Props {
    name: string;
    description: string;
    tag: string;
    actions: { href: string; label: string }[];
}

const { name, description, tag, actions } = Astro.props;
---

<article class="group">
    <div
        class="project-img mb-6 aspect-video flex items-center justify-center border-text/10 bg-text/2"
    >
        <span class="font-mono text-text/20 uppercase tracking-widest text-sm">
            // [Optimized_Launcher_Binary]
        </span>
    </div>

    <div class="flex flex-col gap-4">
        <div class="flex items-center gap-3">
            <span
                class="label-caps text-accent bg-accent-soft px-2 py-0.5 rounded-sm"
                >{tag}</span
            >
            <h3 class="text-xl font-mono tracking-tight text-text">{name}</h3>
        </div>

        <p class="text-base">
            {description}
        </p>

        <div class="flex gap-6 mt-2">
            {
                actions.map((action) => (
                    <a
                        href={action.href}
                        class="font-mono text-sm no-underline hover:text-accent"
                    >
                        {action.label}
                    </a>
                ))
            }
        </div>
    </div>
</article>
