---
interface Props {
    name: string;
    description: string;
    tag: string;
    actions: { href: string; label: string }[];
    image: {
        src: string;
        alt: string;
    };
}

const { name, description, tag, actions, image } = Astro.props;
---

<article class="group">
    <div
        class="project-img mb-6 aspect-video flex items-center justify-center border border-text/10 bg-text/5 overflow-hidden group"
    >
        <img
            src={image.src}
            alt={image.alt}
            class="w-full h-full object-cover opacity-80 group-hover:opacity-100 group-hover:scale-105 transition-all duration-500 ease-out"
        />
    </div>

    <div class="flex flex-col gap-4">
        <div class="flex items-center gap-3">
            <span
                class="label-caps text-accent bg-accent-soft px-2 py-0.5 rounded-sm"
                >{tag}</span
            >
            <h3 class="text-xl font-mono tracking-tight text-text">{name}</h3>
        </div>

        <p class="text-base">
            {description}
        </p>

        <div class="flex gap-6 mt-2">
            {
                actions.map((action) => (
                    <a
                        href={action.href}
                        class="font-mono text-sm no-underline hover:text-accent"
                    >
                        {action.label}
                    </a>
                ))
            }
        </div>
    </div>
</article>
