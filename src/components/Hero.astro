---
import Button from "./Button.astro";
---

<section id="hero" class="portfolio-section pt-44 flex items-center">
    <div class="watermark right-0 top-12">[init]</div>

    <div
        class="max-w-6xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-12 gap-12 items-center relative z-10"
    >
        <div class="lg:col-span-7 space-y-8">
            <div class="space-y-2">
                <span class="label-caps text-sm text-accent">
                    Software_Engineer_Systems_Focus
                </span>
                <h1
                    class="text-5xl md:text-7xl font-mono tracking-tighter leading-tight"
                >
                    José <span class="text-accent">Richiez R.</span>
                </h1>
            </div>

            <p class="max-w-xl text-lg opacity-60 leading-relaxed">
                Engineering at the intersection of <span
                    class="text-text opacity-100">system-level performance</span
                >
                and <span class="text-text opacity-100"
                    >scalable web architecture</span
                >. Driven by a deep-rooted passion for <span
                    class="text-accent opacity-100 italic">open source</span
                >.
            </p>

            <div class="flex flex-wrap gap-4 pt-4">
                <Button
                    label="VIEW_LOGS (Projects)"
                    href="#projects"
                    variant="primary"
                />
                <Button
                    label="CONNECT.remote()"
                    href="#contact"
                    variant="outline"
                />
            </div>
        </div>

        <div class="lg:col-span-5 hidden lg:block">
            <div
                class="p-6 border border-text/10 bg-text/2 backdrop-blur-sm rounded-sm space-y-6 font-mono"
            >
                <div
                    class="flex justify-between items-center border-b border-text/10 pb-4"
                >
                    <span class="text-[10px] opacity-40 uppercase"
                        >Technical_Manifest</span
                    >
                    <div class="flex gap-1.5">
                        <div
                            class="w-2 h-2 rounded-full bg-accent animate-pulse"
                        >
                        </div>
                        <span class="text-[10px] text-accent">READY</span>
                    </div>
                </div>

                <div class="space-y-6">
                    <div class="space-y-2">
                        <span
                            class="text-[9px] opacity-40 block uppercase tracking-widest"
                            >Programming_Languages</span
                        >
                        <div class="flex flex-wrap gap-x-4 gap-y-1">
                            <span class="text-xs">JavaScript</span>
                            <span class="text-xs">Rust</span>
                            <span class="text-xs">Python</span>
                            <span class="text-xs">C#</span>
                            <span class="text-xs">SQL</span>
                            <span class="text-xs">Bash</span>
                        </div>
                    </div>

                    <div class="space-y-2">
                        <span
                            class="text-[9px] opacity-40 block uppercase tracking-widest"
                            >Core_Frameworks</span
                        >
                        <div class="flex flex-wrap gap-x-4 gap-y-1">
                            <span class="text-xs">React</span>
                            <span class="text-xs">Next.js</span>
                            <span class="text-xs">Astro.js</span>
                            <span class="text-xs">React_Native</span>
                            <span class="text-xs">Iced</span>
                            <span class="text-xs">GTK</span>
                        </div>
                    </div>

                    <div class="space-y-2">
                        <span
                            class="text-[9px] opacity-40 block uppercase tracking-widest"
                            >Systems_&_Cloud</span
                        >
                        <div class="grid grid-cols-2 gap-y-1">
                            <span class="text-xs">Linux_Internals</span>
                            <span class="text-xs">AWS_RDS/Cognito</span>
                            <span class="text-xs">PostgreSQL</span>
                            <span class="text-xs">Docker</span>
                            <span class="text-xs">Supabase</span>
                            <span class="text-xs">Deno_Deploy</span>
                        </div>
                    </div>
                </div>

                <div
                    class="pt-4 border-t border-text/10 text-[9px] opacity-30 leading-relaxed italic uppercase tracking-widest"
                >
                    // Built for performance. Optimized for the web.
                    <br />
                    // Proud supporter of the open-source ecosystem.
                </div>
            </div>
        </div>
    </div>
</section>
