---
import MediaLink from "./MediaLink.astro";
import Button from "./Button.astro";
---

<section
    id="contact"
    class="portfolio-section grid grid-cols-1 md:grid-cols-2 gap-16"
>
    <div class="flex flex-col gap-8">
        <h2 class="text-2xl font-mono text-accent">/Contact</h2>

        <form id="contact-form" class="flex flex-col gap-6">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div class="flex flex-col gap-2">
                    <label class="label-caps">Subject</label>
                    <input
                        name="subject"
                        type="text"
                        placeholder="refactor: improve-system-latency"
                        class="bg-text/5 border border-text/10 rounded-sm p-3 font-mono text-sm focus:border-accent outline-none transition-standard"
                    />
                    <span
                        id="subject-error"
                        class="text-red-500 text-xs font-mono"></span>
                </div>
                <div class="flex flex-col gap-2">
                    <label class="label-caps">Return_Path</label>
                    <input
                        name="email"
                        type="email"
                        placeholder="dev@null.local"
                        class="bg-text/5 border border-text/10 rounded-sm p-3 font-mono text-sm focus:border-accent outline-none transition-standard"
                    />
                    <span
                        id="email-error"
                        class="text-red-500 text-xs font-mono"></span>
                </div>
            </div>

            <div class="flex flex-col gap-2">
                <label class="label-caps">Payload</label>
                <textarea
                    name="message"
                    placeholder="fn init_discussion() { /* Your message here */ }"
                    rows="5"
                    class="bg-text/5 border border-text/10 rounded-sm p-3 font-mono text-sm focus:border-accent outline-none transition-standard resize-none"
                ></textarea>
                <span id="message-error" class="text-red-500 text-xs font-mono"
                ></span>
            </div>

            <div class="flex flex-col gap-4">
                <Button
                    type="submit"
                    label="POST request"
                    variant="primary"
                    sublabel="STATUS: READY_FOR_UPLOADING"
                    class="w-full md:w-auto"
                />
                <span id="form-status" class="font-mono text-sm"></span>
            </div>
        </form>
    </div>

    <div class="flex flex-col gap-8 relative">
        <div class="watermark right-0">@</div>

        <div>
            <h3 class="text-2xl font-mono tracking-tight text-text mb-4">
                Find me.
            </h3>
            <p class="mb-8 text-base">
                You can reach out through social networks or use the specific
                channels below for project inquiries.
            </p>
        </div>

        <div class="space-y-6">
            <div>
                <h4 class="label-caps text-xs text-accent">Core_Inquiry</h4>
                <a href="mailto:hello@richiezrijo.com">hello@richiezrijo.com</a>
            </div>

            <div>
                <h4 class="label-caps text-xs text-accent">Other_Work</h4>
                <a href="mailto:interesting@richiezrijo.com"
                    >interesting@richiezrijo.com</a
                >
            </div>
        </div>

        <div
            class="grid grid-cols-2 gap-4 mt-auto pt-10 border-t border-text/10"
        >
            <MediaLink
                href="https://github.com/Wachamuli"
                label="Wachamuli"
                media="Github"
            />
            <MediaLink
                href="https://www.linkedin.com/in/joserichiez/"
                label="joserichiez"
                media="linkedin"
            />
        </div>
    </div>
</section>

<script>
    import { actions, isInputError } from "astro:actions";

    function initContactForm(): void {
        const form = document.querySelector<HTMLFormElement>("#contact-form");
        const status = document.querySelector("#form-status");

        const subjectErr = document.querySelector("#subject-error");
        const emailErr = document.querySelector("#email-error");
        const messageErr = document.querySelector("#message-error");

        if (!form || !status || !subjectErr || !emailErr || !messageErr) {
            console.warn("Contact form UI elements are incomplete.");
            return;
        }

        const errorElements = {
            subject: subjectErr,
            email: emailErr,
            message: messageErr,
        };

        form.addEventListener("submit", async (event) => {
            event.preventDefault();
            status.textContent = "SENDING...";
            status.className = "font-mono text-sm";
            Object.values(errorElements).forEach((el) => (el.textContent = ""));

            const formData = new FormData(form);
            const { data, error } = await actions.sendContactEmail(formData);

            if (error) {
                if (isInputError(error)) {
                    if (error.fields.subject) {
                        errorElements.subject.textContent =
                            error.fields.subject[0];
                    }
                    if (error.fields.email) {
                        errorElements.email.textContent = error.fields.email[0];
                    }
                    if (error.fields.message) {
                        errorElements.message.textContent =
                            error.fields.message[0];
                    }
                    status.textContent = "";
                    return;
                }

                status.textContent = `ERROR: ${error.message}`;
                status.classList.add("text-red-500");
                return;
            }

            status.textContent = `SUCCESS: ${data.message}`;
            status.classList.add("text-green-500");
            form.reset();
        });
    }

    initContactForm();
</script>
