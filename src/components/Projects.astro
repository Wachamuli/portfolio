---
import ProjectCard from "./ProjectCard.astro";
---

<section id="projects" class="portfolio-section">
    <div class="watermark left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2">
        <span class="xl:hidden">{"{}"}</span>
    </div>

    <div
        class="watermark left-0 hidden 2xl:block"
        style="transform: translate(-75%, 50%);"
    >
        {"{"}
    </div>
    <div
        class="watermark right-0 hidden 2xl:block"
        style="transform: translate(75%, 50%);"
    >
        {"}"}
    </div>

    <div class="max-w-6xl mx-auto px-6">
        <div
            class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-16"
        >
            <div>
                <h2 class="text-2xl font-mono text-accent mb-2">/Projects</h2>
                <p class="font-mono opacity-50 tracking-tight">
                    // Selected builds: focus on performance and systems
                    architecture
                </p>
            </div>

            <a
                href="https://github.com/Wachamuli"
                class="group flex items-center gap-2 no-underline"
            >
                <span class="text-xs label-caps text-accent"
                    >View_Full_Archive</span
                >
                <span
                    class="text-accent group-hover:translate-x-1 transition-transform duration-200"
                    >→</span
                >
            </a>
        </div>

        <div
            class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-16 items-stretch"
        >
            <ProjectCard
                repo="Wachamuli/lucien"
                image={{
                    src: "/lucien-launcher.png",
                    alt: "Lucien Application Launcher Interface",
                }}
                name="Lucien"
                tag="System_Tool"
                description="A lightweight Wayland launcher optimized for zero perceived latency. Achieved a 67.5% reduction in syscall overhead through manual implementation of core protocols in Rust."
                actions={[
                    {
                        href: "https://github.com/Wachamuli/lucien",
                        label: "view_source",
                    },
                    {
                        href: "https://www.linkedin.com/posts/joserichiez_linux-opensource-rustlang-activity-7434671551943331840-FM8I?utm_source=share&utm_medium=member_desktop&rcm=ACoAAFRphB4B3BW6lkNu39eNysJrOw06ZulEQSw",
                        label: "performance_metrics",
                    },
                ]}
            />
            <ProjectCard
                image={{
                    src: "/green-residential-mobile.png",
                    alt: "Mobile application Interface",
                }}
                name="Green Residential"
                tag="Full_Stack"
                description="Cross-platform service booking application built with React Native and Supabase. Features a highly scalable PostgreSQL backend."
                actions={[
                    {
                        href: "https://github.com/Wachamuli/GreenD",
                        label: "view_source",
                    },
                ]}
            />
            <ProjectCard
                image={{
                    src: "/morpheus-dekstop-environment.png",
                    alt: "Desktop Environment based on GTK",
                }}
                name="Morpheus"
                tag="Local_First"
                description="Morpheus is a custom-built desktop environment designed to transform barebones Wayland compositors into a fully functional workstation."
                actions={[
                    {
                        href: "https://github.com/Wachamuli/morpheus",
                        label: "view_source",
                    },
                ]}
            />
        </div>
    </div>
</section>
