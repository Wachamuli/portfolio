---
import Button from "./Button.astro";

interface BaseExperience {
    id: string;
    label: string;
    company: string;
}

interface StandardExperience extends BaseExperience {
    isRoot?: false;
    role: string;
    url?: string;
    period: string;
    stack: string[];
    details: string[];
}

interface RootExperience extends BaseExperience {
    isRoot: true;
    roles: {
        role: string;
        url?: string;
        period: string;
        stack: string[];
        details: string[];
    }[];
}

type ExperienceNode = StandardExperience | RootExperience;

const experiences: ExperienceNode[] = [
    {
        id: "01",
        label: "node_health_one",
        role: "Full-Stack Web Developer",
        url: "https://roca-panel.com",
        company: "Health One",
        period: "2025.01 — 2026.02",
        stack: ["Next.js", "AWS", "SQL"],
        details: [
            "Architected relational database schema and back-end logic for AWS scalability.",
            "Developed real-time Alert Notification and Payment Tracking modules.",
        ],
    },
    {
        id: "02",
        label: "node_smsu_root",
        company: "Southwest Minnesota State University",
        isRoot: true,
        roles: [
            {
                role: "Full-Stack Web Developer",
                url: "https://rebuild2reintegrate.com",
                period: "2025.01 — 2025.12",
                stack: ["React", "Astro.js", "Supabase", "GitHub Actions"],
                details: [
                    "Led end-to-end development of the Rebuild2Reintegrate project.",
                    "Architected CI/CD pipelines for seamless Deno Deploy integration.",
                ],
            },
            {
                role: "Unix Laboratory Assistant",
                period: "2024.09 — 2025.12",
                stack: ["Linux", "Python", "Bash"],
                details: [
                    "Provided tutoring in foundational CS courses including data structures and algorithms.",
                    "Simplified complex technical topics for diverse learning styles in the CS Lab.",
                ],
            },
        ],
    },
];
---

<section
    id="experience"
    class="relative py-32 border-t border-text/5 overflow-hidden"
>
    <div class="watermark left-0" style="transform: translate(20%, 20%);">
        {"~"}
    </div>

    <div
        class="max-w-6xl mx-auto px-6 mb-24 grid grid-cols-1 md:grid-cols-2 gap-16 items-end"
    >
        <div class="space-y-4">
            <h2 class="text-2xl font-mono text-accent">/Experience</h2>
            <p class="font-mono opacity-50 tracking-tight">
                // Professional lifecycle and technical contributions
            </p>
        </div>

        <div class="flex flex-col md:items-end gap-4">
            <span class="label-caps text-accent">Export_Artifact</span>
            <Button
                href="/Systems-Engineer-Resume-Jose-Richiez.pdf"
                label="GET resume.pdf"
                variant="primary"
                sublabel="SHA256: 5F4DCC3B..."
            />
        </div>
    </div>

    <div class="max-w-4xl mx-auto px-6 relative">
        <div
            class="relative border-l border-text/10 ml-4 md:ml-8 pl-8 md:pl-12 space-y-24"
        >
            {
                experiences.map((node) => (
                    <div class="relative group">
                        <div class="absolute -left-8.25 md:-left-12.25 top-4 w-8 md:w-12 h-px bg-text/10" />
                        <div class="absolute -left-9.25 md:-left-13.25 top-3.25 w-2 h-2 rounded-full border border-text/20 bg-background group-hover:border-accent transition-all" />

                        {node.isRoot ? (
                            <div class="space-y-12">
                                <div class="flex items-center gap-4">
                                    <span class="font-mono text-[10px] text-accent opacity-50">
                                        [dir]
                                    </span>
                                    <h3 class="text-xl font-mono text-accent">
                                        {node.company}
                                    </h3>
                                </div>

                                <div class="ml-2 border-l border-accent/20 pl-8 space-y-16">
                                    {node.roles.map((subRole) => (
                                        <div class="relative">
                                            <div class="absolute -left-8.25 top-3 w-6 h-px bg-accent/20" />
                                            <div class="space-y-3">
                                                <div class="flex items-center gap-3">
                                                    <h4 class="text-lg font-mono">
                                                        {subRole.role}
                                                    </h4>
                                                    {subRole.url && (
                                                        <a
                                                            href={subRole.url}
                                                            target="_blank"
                                                            rel="noopener noreferrer"
                                                            class="px-2 py-0.5 border border-accent/30 text-accent font-mono text-[9px] hover:bg-accent/10 transition-all flex items-center gap-1.5 no-underline"
                                                        >
                                                            <span class="opacity-50">
                                                                HTTP
                                                            </span>{" "}
                                                            VISIT ↗
                                                        </a>
                                                    )}
                                                </div>
                                                <p class="font-mono text-[10px] opacity-40 uppercase tracking-widest">
                                                    {subRole.period}
                                                </p>
                                                <ul class="space-y-2 max-w-xl">
                                                    {subRole.details.map(
                                                        (detail) => (
                                                            <li class="font-mono text-sm opacity-70 flex gap-3">
                                                                <span class="text-accent/30">
                                                                    ├─
                                                                </span>{" "}
                                                                {detail}
                                                            </li>
                                                        ),
                                                    )}
                                                </ul>
                                                <div class="flex flex-wrap gap-2 pt-2">
                                                    {subRole.stack.map(
                                                        (tech) => (
                                                            <span class="px-2 py-0.5 bg-text/5 border border-text/10 font-mono text-[9px] opacity-50 uppercase">
                                                                {tech}
                                                            </span>
                                                        ),
                                                    )}
                                                </div>
                                            </div>
                                        </div>
                                    ))}
                                </div>
                            </div>
                        ) : (
                            <div class="space-y-4">
                                <div class="flex flex-col md:flex-row md:items-center gap-2 md:gap-4">
                                    <span class="font-mono text-[10px] text-accent opacity-50">
                                        [node]
                                    </span>
                                    <div class="flex items-center gap-3">
                                        <h3 class="text-xl font-mono">
                                            {node.role}
                                        </h3>
                                        {node.url && (
                                            <a
                                                href={node.url}
                                                target="_blank"
                                                rel="noopener noreferrer"
                                                class="px-2 py-0.5 border border-accent/30 text-accent font-mono text-[9px] hover:bg-accent/10 transition-all flex items-center gap-1.5 no-underline"
                                            >
                                                <span class="opacity-50">
                                                    HTTP
                                                </span>{" "}
                                                VISIT ↗
                                            </a>
                                        )}
                                    </div>
                                </div>
                                <p class="font-mono text-xs opacity-40">
                                    @ {node.company} // {node.period}
                                </p>
                                <ul class="space-y-3 max-w-2xl">
                                    {node.details.map((detail) => (
                                        <li class="font-mono text-sm opacity-70 flex gap-3">
                                            <span class="text-accent/30">
                                                ├─
                                            </span>{" "}
                                            {detail}
                                        </li>
                                    ))}
                                </ul>
                                <div class="flex flex-wrap gap-2 pt-2">
                                    {node.stack.map((tech) => (
                                        <span class="px-2 py-0.5 bg-text/5 border border-text/10 font-mono text-[9px] opacity-50 uppercase">
                                            {tech}
                                        </span>
                                    ))}
                                </div>
                            </div>
                        )}
                    </div>
                ))
            }
        </div>
    </div>
</section>
