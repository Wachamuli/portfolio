---
import type { GitHubStats } from "../types";
import { GITHUB_ACCESS_TOKEN } from "astro:env/server";

interface Props {
    repo: string;
}

const { repo } = Astro.props;

const url = `https://api.github.com/repos/${repo}`;
const requestInit = {
    headers: {
        Authorization: `Bearer ${GITHUB_ACCESS_TOKEN}`,
        Accept: "application/vnd.github+json",
        "User-Agent": "Astro-Cloudflare-App",
    },
};
const data = await fetch(url, requestInit)
    .then((r) => (r.ok ? r.json<GitHubStats>() : null))
    .catch(() => null);
const stargazers_count = data?.stargazers_count?.toLocaleString() ?? "—";
const forks_count = data?.forks_count?.toLocaleString() ?? "—";
const githubStats = { stargazers_count, forks_count };
---

<div
    class="flex items-center border border-text/10 bg-text/5 rounded-sm divide-x divide-text/10"
>
    <div class="flex items-center gap-1.5 px-2 py-0.5">
        <span class="text-[10px] text-accent label-caps">STARS</span>
        <span class="text-[10px] font-mono text-text"
            >★ {githubStats.stargazers_count}</span
        >
    </div>
    <div class="flex items-center gap-1.5 px-2 py-0.5">
        <span class="text-[10px] text-accent label-caps">FORKS</span>
        <span class="text-[10px] font-mono text-text">
            {githubStats.forks_count}</span
        >
    </div>
</div>
