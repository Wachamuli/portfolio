---
import { env } from "cloudflare:workers";

interface Props {
    repo: string;
}

const { repo } = Astro.props;

let stars = "0";
let forks = "0";
try {
    const res = await fetch(`https://api.github.com/repos/${repo}`, {
        headers: {
            Authorization: `Bearer ${env.GITHUB_ACCESS_TOKEN}`,
            Accept: "application/vnd.github+json",
            "User-Agent": "Astro-Cloudflare-App",
        },
    });
    if (res.ok) {
        const data = await res.json();
        stars = data.stargazers_count.toLocaleString();
        forks = data.forks_count.toLocaleString();
    }
} catch (e) {
    stars = "—";
    forks = "—";
}
---

<div
    class="flex items-center border border-text/10 bg-text/5 rounded-sm divide-x divide-text/10"
>
    <div class="flex items-center gap-1.5 px-2 py-0.5">
        <span class="text-[10px] text-accent label-caps">STARS</span>
        <span class="text-[10px] font-mono text-text">★ {stars}</span>
    </div>
    <div class="flex items-center gap-1.5 px-2 py-0.5">
        <span class="text-[10px] text-accent label-caps">FORKS</span>
        <span class="text-[10px] font-mono text-text"> {forks}</span>
    </div>
</div>
