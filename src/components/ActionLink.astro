---
interface Props {
    href: string;
    label?: string;
    class?: string;
}

const { href, label = "LINK", class: className } = Astro.props;
---

<a
    href={href}
    target="_blank"
    rel="noopener noreferrer"
    class:list={[
        "inline-flex items-center gap-2 px-2.5 py-1 rounded-sm cursor-pointer",
        "text-[10px] label-caps",
        "text-accent bg-accent/5 border border-accent/20",
        "hover:bg-accent/10 hover:border-accent/40 hover:text-accent",
        "transition-all duration-200 no-underline shrink-0 group",
        className,
    ]}
>
    <span class="leading-none">{label}</span>
    <span
        class="text-[12px] opacity-70 group-hover:opacity-100 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-all duration-300"
    >
        ↗
    </span>
</a>
