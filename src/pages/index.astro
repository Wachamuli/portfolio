---
import Layout from "../layouts/Layout.astro";
---

<Layout>
    <section class="p-8 max-w-4xl mx-auto space-y-12">
        <div class="space-y-6 border-b pb-8 border-background">
            <h1 class="text-4xl text-accent">Lilex Fluid Header 1</h1>

            <h2 class="text-2xl">Fluid Header 2</h2>

            <p>
                This is your <span class="text-accent font-bold"
                    >Inter Sans</span
                > body text. It's optimized for reading technical documentation. Because
                of your base styles, this paragraph will never exceed a comfortable
                reading width, maintaining perfect vertical rhythm.
            </p>

            <div class="flex items-center gap-4">
                <code
                    class="font-mono bg-background px-2 py-1 rounded text-accent border border-accent/10"
                >
                    {"fn optimize_boot_time() -> u32 {16}"}
                </code>
                <span class="text-xs font-mono text-text/50"
                    >// Optimized for Wayland</span
                >
            </div>
        </div>

        <div class="space-y-4">
            <h3 class="text-sm uppercase tracking-widest text-text/50">
                System Palette
            </h3>
            <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
                <div class="space-y-2">
                    <div
                        class="aspect-square rounded-lg bg-accent shadow-lg shadow-accent/20"
                    >
                    </div>
                    <span class="font-mono text-xs block text-center"
                        >Accent</span
                    >
                </div>
                <div class="space-y-2">
                    <div
                        class="aspect-square rounded-lg bg-accent-soft border border-accent/20"
                    >
                    </div>
                    <span class="font-mono text-xs block text-center"
                        >Soft Accent</span
                    >
                </div>
                <div class="space-y-2">
                    <div
                        class="aspect-square rounded-lg bg-primary border border-background"
                    >
                    </div>
                    <span class="font-mono text-xs block text-center"
                        >Surface</span
                    >
                </div>
                <div class="space-y-2">
                    <div class="aspect-square rounded-lg bg-background"></div>
                    <span class="font-mono text-xs block text-center"
                        >Ground</span
                    >
                </div>
                <div class="space-y-2">
                    <div class="aspect-square rounded-lg bg-text"></div>
                    <span class="font-mono text-xs block text-center">Ink</span>
                </div>
            </div>
        </div>

        <div class="grid md:grid-cols-2 gap-8">
            <div
                class="bg-primary p-6 rounded-xl border border-background shadow-sm space-y-4"
            >
                <span
                    class="bg-accent-soft text-accent font-mono text-[10px] px-2 py-0.5 rounded-full uppercase font-bold border border-accent/10"
                >
                    Systems Tool
                </span>
                <h4 class="text-xl">Project: Lucien</h4>
                <p class="text-sm text-text/80">
                    High-performance launcher built in Rust. Sub-16ms startup
                    achieved via minimal syscall overhead.
                </p>
                <button
                    class="bg-accent text-primary px-6 py-2 rounded font-bold hover:brightness-110"
                >
                    Source Code
                </button>
            </div>

            <div
                class="project-img aspect-video flex items-center justify-center group cursor-pointer"
            >
                <div
                    class="text-center group-hover:scale-110 transition-transform"
                >
                    <p class="font-mono text-accent text-xs">
                        // Image Placeholder
                    </p>
                    <p class="text-[10px] text-text/40">
                        Hover to see translateY & border-color transition
                    </p>
                </div>
            </div>
        </div>
    </section>
</Layout>
